{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Group GitHub Actions digest bumps into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Group mise tool bumps per image",
      "matchManagers": ["mise"],
      "groupName": "mise tools"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Version pins annotated with `# renovate:` in Dockerfiles and the Makefile",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/",
        "/(^|/)Makefile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+ARG \\w+=\"?(?<currentValue>[^\"\\s]+)\"?",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+\\w+ := (?<currentValue>\\S+)"
      ],
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver{{/if}}"
    }
  ]
}
